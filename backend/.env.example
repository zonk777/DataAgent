# 应用配置
APP_NAME=DataAgent
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-string
DATABASE_BACKEND=mysql
DATABASE_PATH=storage/data_agent.db
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=dataagent
MYSQL_PASSWORD=dataagent123
MYSQL_DATABASE=dataagent
FRONTEND_ORIGIN=http://localhost:5173

# 大模型配置（留空时自动使用本地演示分析器）
# 支持 OpenAI 兼容的 Chat Completions 接口。
LLM_API_KEY=sk-46cf80e3c5124a12a3523d11dfde2851
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Embedding 配置。可使用 BGE（如 BAAI/bge-m3）或其他 OpenAI 兼容 Embedding 模型。
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=BAAI/bge-m3

# 向量索引：qdrant / faiss / milvus。qdrant 与 faiss 适合本地轻量部署，milvus 适合集群部署。
VECTOR_STORE=qdrant
QDRANT_PATH=storage/qdrant
FAISS_PATH=storage/faiss
MILVUS_URI=
MILVUS_TOKEN=
MILVUS_DATABASE=
SEMANTIC_SEARCH_TIMEOUT_SECONDS=1.0

# 安全限制
MAX_UPLOAD_MB=100
QUERY_ROW_LIMIT=500
SQL_TIMEOUT_SECONDS=15
